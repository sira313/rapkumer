# URL atau PATH ke file database, default-nya: "file:./data/database.sqlite3"
DB_URL=file:./data/database.sqlite3
# Lokasi untuk menyimpan foto (format: file:<absolute-or-relative-path>)
# Contoh Windows: photo=file:C:\Users\User\AppData\Local\Rapkumer-data\upoads
photo=file:./data/uploads
# Lokasi untuk menyimpan file sound bell (format: file:<absolute-or-relative-path>)
# Contoh Windows: sounds=file:C:\Users\User\AppData\Local\Rapkumer-data\sounds
sounds=file:./data/sounds
# Path ke binary Chrome/Chromium untuk rendering PDF via PagedJS + Puppeteer.
# Jika tidak diisi, akan otomatis mencari di lokasi umum.
# Contoh Linux: PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# Contoh Windows: PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# PUPPETEER_EXECUTABLE_PATH=
