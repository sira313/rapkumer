{
	"name": "rapkumer",
	"private": true,
	"version": "1.6.3",
	"type": "module",
	"scripts": {
		"db:push": "node scripts/migrate-installed-db.mjs",
		"seed:walis": "node scripts/seed-wali-users.mjs",
		"db:studio": "drizzle-kit studio",
		"db:cleanup": "node scripts/cleanup-orphans.mjs",
		"dev": "node scripts/dev.js",
		"build": "vite build",
		"preview": "vite preview",
		"start": "node scripts/start-build.mjs",
		"package:win": "node scripts/prepare-windows.mjs",
		"package:win:installer": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"& 'C:\\Program Files (x86)\\Inno Setup 6\\ISCC.exe' 'installer/raporkumer.iss'\"",
		"sign:executables": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/scripts/sign-files.ps1 -SignExecutables",
		"sign:installer": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/scripts/sign-files.ps1 -SignInstaller",
		"sign:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/scripts/sign-files.ps1 -VerifyOnly -SignExecutables -SignInstaller",
		"sign:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/scripts/setup-signing.ps1 -Setup",
		"sign:create-cert": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/scripts/setup-signing.ps1 -CreateSelfSigned",
		"sign:create-cert:force": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/scripts/setup-signing.ps1 -CreateSelfSigned -Force",
		"prepare": "svelte-kit sync || echo ''",
		"version": "node scripts/update-version.mjs",
		"check": "svelte-kit sync && node scripts/svelte-check-wrapper.mjs",
		"check:watch": "svelte-kit sync && node scripts/svelte-check-wrapper.mjs --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"prod": "node scripts/cleanup-db.mjs && node scripts/prod-unsigned.mjs",
		"prod:signed": "node scripts/cleanup-db.mjs && node scripts/prod-signed.mjs"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.4",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.1",
		"@types/qrcode": "^1.5.6",
		"daisyui": "^5.5.20",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^16.5.0",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.4",
		"vite": "^7.3.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"yaml": "^2.9.0"
	},
	"dependencies": {
		"@libsql/client": "^0.15.15",
		"drizzle-orm": "^0.44.7",
		"exceljs": "^4.4.0",
		"jsqr": "^1.4.0",
		"pagedjs-cli": "^0.4.3",
		"pdf-lib": "^1.17.1",
		"puppeteer-core": "^25.1.0",
		"qrcode": "^1.5.4",
		"unzipper": "^0.12.3"
	}
}
